{
  "apps": [
    {
      "id": "terminal",
      "name": "Terminal",
      "windows_command": "wt.exe",
      "linux_command": "gnome-terminal",
      "macos_command": "open -a Terminal",
      "icon": null,
      "category": "system"
    },
    {
      "id": "browser",
      "name": "Web Browser",
      "windows_command": "start microsoft-edge:",
      "linux_command": "xdg-open https://www.google.com",
      "macos_command": "open https://www.google.com",
      "icon": null,
      "category": "web"
    },
    {
      "id": "explorer",
      "name": "File Explorer",
      "windows_command": "explorer.exe",
      "linux_command": "nautilus",
      "macos_command": "open .",
      "icon": null,
      "category": "system"
    },
    {
      "id": "settings",
      "name": "Settings",
      "windows_command": "start ms-settings:",
      "linux_command": "gnome-control-center",
      "macos_command": "open -a 'System Settings'",
      "icon": null,
      "category": "system"
    },
    {
      "id": "calculator",
      "name": "Calculator",
      "windows_command": "calc.exe",
      "linux_command": "gnome-calculator",
      "macos_command": "open -a Calculator",
      "icon": null,
      "category": "utilities"
    },
    {
      "id": "text_editor",
      "name": "Text Editor",
      "windows_command": "notepad.exe",
      "linux_command": "gedit",
      "macos_command": "open -a TextEdit",
      "icon": null,
      "category": "utilities"
    },
    {
      "id": "task_manager",
      "name": "Task Manager / System Monitor",
      "windows_command": "taskmgr.exe",
      "linux_command": "gnome-system-monitor",
      "macos_command": "open -a 'Activity Monitor'",
      "icon": null,
      "category": "system"
    },
    {
      "id": "office_word",
      "name": "Microsoft Word",
      "windows_command": "start \"\" winword.exe",
      "linux_command": "if command -v libreoffice >/dev/null 2>&1; then libreoffice --writer; else xdg-open https://www.office.com/launch/word; fi",
      "macos_command": "open -a \"Microsoft Word\"",
      "icon": null,
      "category": "office"
    },
    {
      "id": "office_excel",
      "name": "Microsoft Excel",
      "windows_command": "start \"\" excel.exe",
      "linux_command": "if command -v libreoffice >/dev/null 2>&1; then libreoffice --calc; else xdg-open https://www.office.com/launch/excel; fi",
      "macos_command": "open -a \"Microsoft Excel\"",
      "icon": null,
      "category": "office"
    },
    {
      "id": "office_powerpoint",
      "name": "Microsoft PowerPoint",
      "windows_command": "start \"\" powerpnt.exe",
      "linux_command": "if command -v libreoffice >/dev/null 2>&1; then libreoffice --impress; else xdg-open https://www.office.com/launch/powerpoint; fi",
      "macos_command": "open -a \"Microsoft PowerPoint\"",
      "icon": null,
      "category": "office"
    },
    {
      "id": "office_outlook",
      "name": "Microsoft Outlook (Office 365)",
      "windows_command": "start https://outlook.office.com",
      "linux_command": "xdg-open https://outlook.office.com",
      "macos_command": "open https://outlook.office.com",
      "icon": null,
      "category": "office"
    },
    {
      "id": "office_onenote",
      "name": "Microsoft OneNote (Office 365)",
      "windows_command": "start https://www.onenote.com",
      "linux_command": "xdg-open https://www.onenote.com",
      "macos_command": "open https://www.onenote.com",
      "icon": null,
      "category": "office"
    },
    {
      "id": "office_teams",
      "name": "Microsoft Teams (Office 365)",
      "windows_command": "start https://teams.microsoft.com",
      "linux_command": "xdg-open https://teams.microsoft.com",
      "macos_command": "open https://teams.microsoft.com",
      "icon": null,
      "category": "office"
    },
    {
      "id": "office_onedrive",
      "name": "Microsoft OneDrive (Office 365)",
      "windows_command": "start https://onedrive.live.com",
      "linux_command": "xdg-open https://onedrive.live.com",
      "macos_command": "open https://onedrive.live.com",
      "icon": null,
      "category": "office"
    }
  ]
}
